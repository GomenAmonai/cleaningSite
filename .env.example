# Sanity (read — exposed to the browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# Optional, defaults to a date pinned in sanity/env.ts
NEXT_PUBLIC_SANITY_API_VERSION=

# Sanity (write — server only). Used by:
#   - the submit-inquiry server action to persist form submissions
#   - the seed script (npm run seed)
SANITY_API_WRITE_TOKEN=

# Telegram bot for inquiry delivery (server only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
